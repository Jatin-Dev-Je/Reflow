# Frontend env vars (Vite — only variables prefixed VITE_ are exposed to client).

# Backend API base URL — leave empty in dev to use the Vite proxy.
VITE_API_BASE_URL=

# WebSocket base URL — leave empty in dev to use the Vite proxy.
VITE_WS_BASE_URL=

# Public app metadata
VITE_APP_NAME=Reflow
VITE_APP_VERSION=0.1.0

# Optional: error tracking
VITE_SENTRY_DSN=
