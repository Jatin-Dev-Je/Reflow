    "openapi-fetch": "^0.13.4",

    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.9.1",
    "zod": "^3.24.1",

    "recharts": "^2.15.0",
    "@tremor/react": "^3.18.7",

    "react-use-websocket": "^4.11.1",

    "lucide-react": "^0.468.0",
