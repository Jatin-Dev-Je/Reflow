# --- App ---
APP_ENV=development
APP_NAME=reflow-backend
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://reflow:reflow@localhost:5432/reflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# --- Security ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=60
AUDIT_LOG_SIGNING_KEY=change-me-in-production

# --- LLM Providers (free tiers) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDER=gemini

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Observability ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=

# --- Notifications ---
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# --- Payment Gateways ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Simulation ---
SIMULATION_SEED=42
SIMULATION_DEFAULT_SIZE=50000
